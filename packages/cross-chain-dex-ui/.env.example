# L1 RPC URL (for reading balances, creating smart wallet)
VITE_L1_RPC_URL=

# L2 RPC URL (for reading DEX reserves)
VITE_L2_RPC_URL=

# Builder RPC URL (for sending UserOps)
VITE_BUILDER_RPC_URL=http://localhost:4545

# Chain ID for L1
VITE_CHAIN_ID=31337

# L1 chain display config (defaults: Gnosis / xDAI if not set)
# VITE_L1_CHAIN_NAME=Surge Devnet
# VITE_L1_NATIVE_SYMBOL=ETH
# VITE_L1_NATIVE_NAME=Ether

# Safe contract addresses (same on both chains)
VITE_SAFE_PROXY_FACTORY=0x58AFc212667A0EB72148bEAFFAc1A542c6a29177
VITE_SAFE_SINGLETON=0x2d45De2E0e2091677d3d8199e44bb83B5F6Ada06
VITE_SAFE_MULTISEND=0x1F1f2eea04c0D932D09163f949308cFbB9cab970
VITE_SAFE_FALLBACK_HANDLER=0x221B688d8582B6a34870543ecE7ae2C2D3DD72B6

# Contract addresses (update after deployment)
VITE_L1_VAULT=0x0000000000000000000000000000000000000000
VITE_USDC_TOKEN=0x0000000000000000000000000000000000000000
VITE_USDC_DECIMALS=18
VITE_SIMPLE_DEX=0x0000000000000000000000000000000000000000

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here
