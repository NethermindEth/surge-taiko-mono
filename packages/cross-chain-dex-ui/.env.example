# L1 RPC URL (for reading balances, creating smart wallet)
VITE_L1_RPC_URL=

# L2 RPC URL (for reading DEX reserves)
VITE_L2_RPC_URL=

# Builder RPC URL (for sending UserOps)
VITE_BUILDER_RPC_URL=http://host.docker.internal:4545 # Builder urls should remain docker host if both UI and Catalyst are running inside containers
VITE_BUILDER_API_URL=http://host.docker.internal:4545 # Builder urls should remain docker host if both UI and Catalyst are running inside containers

# Chain ID for L1
VITE_CHAIN_ID=11155111

# L1 chain display config (defaults: Gnosis / xDAI if not set)
VITE_L1_CHAIN_NAME=Surge Devnet
VITE_L1_NATIVE_SYMBOL=ETH
VITE_L1_NATIVE_NAME=Ether
VITE_L1_NATIVE_LOGO=/eth-logo.svg

# Safe contract addresses (same on both chains)
VITE_SAFE_PROXY_FACTORY=0x4e1DCf7AD4e460CfD30791CCC4F9c8a4f820ec67
