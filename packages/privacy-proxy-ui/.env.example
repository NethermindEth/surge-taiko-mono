# Privacy-proxy base URL used by the Vite dev proxy. UI fetches /api/* → ${VITE_PROXY_URL}/*
VITE_PROXY_URL=http://127.0.0.1:8080

# WalletConnect Cloud project id. Anything non-empty works for local dev.
VITE_WALLETCONNECT_PROJECT_ID=privacy-proxy-local

# Branding shown in the topbar and on the login screen.
VITE_APP_NAME=Surge Access Control Panel
